{
  "cli": {
    "version": ">= 12.0.0"
  },
  "build": {
    "simulator": {
      "developmentClient": false,
      "distribution": "internal",
      "ios": {
        "simulator": true
      },
      "env": {
        "EXPO_USE_PNPM": "1"
      }
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "EXPO_USE_PNPM": "1"
      }
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "EXPO_USE_PNPM": "1"
      }
    }
  }
}
