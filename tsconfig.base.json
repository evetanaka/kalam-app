{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "paths": {
      "@kalam/theme": ["./packages/theme/src"],
      "@kalam/ui": ["./packages/ui/src"],
      "@kalam/stores": ["./packages/stores/src"],
      "@kalam/i18n": ["./packages/i18n/src"]
    }
  },
  "exclude": ["node_modules", "dist", "build"]
}
